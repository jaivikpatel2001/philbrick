# =============================================================================
# VERTIQ static site — Apache/cPanel configuration
# Ships inside the export (out/) so uploading to public_html "just works".
# Render/CDN hosts ignore this file. Requires mod_rewrite (standard on cPanel).
# =============================================================================

# No directory listings; no content-negotiation surprises
Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Launch hardening (enable after the final domain + SSL are live): ---
  # Force HTTPS and the canonical www host so served URLs match SITE.url.
  # Replace example.com with the real domain, then remove the leading #s.
  # RewriteCond %{HTTPS} off [OR]
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^ https://www.example.com%{REQUEST_URI} [R=301,L]

  # Trim trailing slashes so /about/ resolves like /about
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # Clean URLs: if the request isn't a real file, serve its .html twin
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Branded 404 (exported by Next as /404.html)
ErrorDocument 404 /404.html

# --- Compression -------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/xml application/javascript application/json image/svg+xml
</IfModule>

# --- Caching -----------------------------------------------------------------
<IfModule mod_headers.c>
  # Build assets under /_next/static are content-hashed: safe to cache forever
  <FilesMatch "\.(js|css|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Icons/illustrations: a week is plenty
  <FilesMatch "\.(svg|png|ico|jpg|webp|avif)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  # HTML + feeds always revalidate so deploys show up immediately
  <FilesMatch "\.(html|xml|txt)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
